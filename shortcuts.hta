        <input type="text" id="shortcut5"></br>
				<input type="button" value="..." id ="selector1" class="selector">
        <input type="text" id="shortcut6"></br>		
		<hr style="width:100%; border: 0; border-top: 1px solid #C4D0C6;">
	</div>	 
		 <input type="button" value="Browse..."
			style="margin-bottom:70px"	onclick="browseExplorer" >			
    </div>
</body>

</html>	


