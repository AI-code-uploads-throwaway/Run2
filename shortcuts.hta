<html>
<head>
<meta content="ie=9">
<title>Run2</title>
<hta:application 
    id="Run2" 
    border="dialog" 
    innerborder="no" 
    scroll="no" 
    sysmenu="no"
    caption="yes"
    windowstate="normal" >
</head>

<style>	
    body { 
	 background-color: #C4D0C6; font-family: "Tahoma", sans-serif; font-size: 8pt; 
	 }
	.main-layout {
	
	 }
    .UI-layout { 
	 display: flex; flex-direction: column;
	 background-color: #D4D0CA;
	 gap: 15px; 
	 }	 
    input { 
	 margin-bottom: 5px; padding: 2px; 
	 border: 1px inset #C4D0C6;
	 }
	.selector { 
	 text-align: center;
	 width: 17px; height: 17px;
	 margin: 0px 5px 5px 0px;   
	 border: 2px; inset whatever;
	}	 
	 *{box-sizing: border-box;} 
    .label { 
	 font: unset;  
	 margin-bottom: 3px; 
	 }	
</style>

<body>
		<hr style="width:100%; border: 0; border-top: 1px solid #C4D0C6;">
	<div class="main-layout">
